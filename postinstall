#!/usr/bin/env bash
#
# Calamares shellprocess hook: runs inside the installer chroot.
# Installs Ansible, clones this repo, and registers the first-boot service.
# Everything else runs via ansible-playbook on first boot.
#
set -euo pipefail

REPO_URL="https://github.com/schmonz/gatherd.git"
DEST="/usr/local/lib/gatherd"
SWAY_CE_URL="https://raw.githubusercontent.com/EndeavourOS-Community-Editions/sway/main/setup_sway_isomode.bash"

target_user=$(awk -F: '$3 >= 1000 && $3 < 65534 { print $1; exit }' /etc/passwd)

curl -fsSL "$SWAY_CE_URL" | bash -s -- "$target_user"

pacman -S --noconfirm --needed ansible git rate-mirrors

[[ -d "$DEST/.git" ]] || git clone "$REPO_URL" "$DEST"

# Select fastest mirrors once, before the first Ansible run needs them.
mirror_flavor=$([ "$(uname -m)" = "aarch64" ] && echo archarm || echo arch)
rate-mirrors --per-mirror-timeout 1500 "$mirror_flavor" > /etc/pacman.d/mirrorlist

ln -sf "$DEST/gatherd.service" /etc/systemd/system/gatherd.service
ln -sf "$DEST/gatherd-slow.service" /etc/systemd/system/gatherd-slow.service
systemctl enable gatherd.service gatherd-slow.service

# Pre-mask services that conflict with TLP so they never start on first boot.
# Without this, power-profiles-daemon starts (and fails) before Ansible can
# mask it, leaving systemd in a state that can hang TLP's startup.
systemctl mask power-profiles-daemon.service systemd-rfkill.service systemd-rfkill.socket
