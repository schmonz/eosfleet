#!/bin/sh
# Opens iCloud.com when rclone iCloud auth has expired, then extracts
# cookies and updates rclone automatically. Tokens expire monthly.

# --password-store=basic (in helium-browser-flags.conf) keeps this DB readable.
_db="$HOME/.config/net.imput.helium/Default/Cookies"

icloud_authenticated() {
    timeout 10 rclone lsd icloud: --max-depth 0 >/dev/null 2>&1
}

query_cookies() {
    sqlite3 "$_db" "$1" 2>/dev/null
}

wait_for_login() {
    # DSID is Apple's session cookie — present for all logins, not just 2FA.
    _deadline=$(( $(date +%s) + 300 ))
    while [ "$(date +%s)" -lt "$_deadline" ]; do
        query_cookies "SELECT value FROM cookies WHERE name='DSID' AND host_key LIKE '%.apple.com'" \
            | grep -q . && return 0
        sleep 3
    done
    return 1
}

extract_cookies() {
    query_cookies "SELECT name || '=' || value FROM cookies WHERE host_key LIKE '%.apple.com'" \
        | awk 'NR>1{printf "; "} {printf "%s", $0}'
}

extract_trust() {
    query_cookies "SELECT value FROM cookies WHERE name='X-APPLE-WEBAUTH-HSA-TRUST' AND host_key LIKE '%.apple.com'"
}

main() {
    command -v rclone >/dev/null || return
    command -v sqlite3 >/dev/null || return
    rclone listremotes | grep -q '^icloud:' || return
    icloud_authenticated && return

    xdg-open https://www.icloud.com
    wait_for_login || return

    rclone config update icloud cookies="$(extract_cookies)" trust_token="$(extract_trust)"
    notify-send "iCloud" "Authentication updated — rclone is ready"
}

main "$@"
exit $?
