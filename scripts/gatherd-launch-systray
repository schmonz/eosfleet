#!/bin/sh
# Wait for waybar's StatusNotifierWatcher once, then launch all systray apps.
# Centralizing the wait here keeps individual systray scripts simple.
until busctl --user status org.kde.StatusNotifierWatcher >/dev/null 2>&1; do
    sleep 1
done
gatherd-systray-1password &
gatherd-systray-localsend &
gatherd-systray-tailscale &
gatherd-systray-updater &
